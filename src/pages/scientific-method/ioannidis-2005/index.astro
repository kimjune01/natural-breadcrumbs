        <text x="120" y="120" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.3">(100 of 1000)</text>
        <text x="120" y="200" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">Hypothesis false</text>
        <text x="120" y="210" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.3">(900 of 1000)</text>

        <!-- True positive cell -->
        <rect x="190" y="75" width="140" height="70" rx="4" fill="#4ade80" fill-opacity="0.12" stroke="#4ade80" stroke-width="1.5"/>
