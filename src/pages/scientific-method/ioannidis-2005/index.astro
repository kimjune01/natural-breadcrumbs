        <text x="235" y="210" text-anchor="middle" fill="currentColor" font-size="8" fill-opacity="0.4">p-value</text>
        <text x="20" y="100" text-anchor="middle" fill="currentColor" font-size="8" fill-opacity="0.4" transform="rotate(-90, 20, 100)">frequency</text>

        <!-- X-axis ticks -->
