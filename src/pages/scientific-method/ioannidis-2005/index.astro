        <text x="400" y="125" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.3">false negatives</text>

        <!-- False positive cell -->
        <rect x="190" y="155" width="140" height="70" rx="4" fill="#ef4444" fill-opacity="0.15" stroke="#ef4444" stroke-width="1.5"/>
