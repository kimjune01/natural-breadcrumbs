        <text x="42" y="187" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">30</text>
        <rect x="72" y="168" width="44" height="28" rx="3" fill="#facc15" fill-opacity="0.15"/>
        <text x="94" y="187" text-anchor="middle" fill="#facc15" font-size="13">31</text>
        <text x="146" y="187" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">32</text>
        <text x="198" y="187" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">33</text>
        <text x="250" y="187" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">34</text>
