        <text x="42" y="152" text-anchor="middle" fill="#facc15" font-size="13">23</text>
        <text x="94" y="152" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">24</text>
        <text x="146" y="152" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">25</text>
        <text x="198" y="152" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">26</text>
        <text x="250" y="152" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">27</text>
        <text x="302" y="152" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">28</text>
        <rect x="332" y="133" width="44" height="28" rx="3" fill="#facc15" fill-opacity="0.15"/>
        <text x="354" y="152" text-anchor="middle" fill="#facc15" font-size="13">29</text>
