---
import Layout from '../../layouts/Base.astro';
import Neighbors from "../../components/Neighbors.astro";
---

<Layout title="Operating Systems" favicon="🖥">
  <main>

    <a href="/reading/" class="text-sm mb-4 inline-block">&larr; back to reading</a>

    <h1>🖥 Operating Systems</h1>
    <p class="text-gray-400 mb-2">Based on <a href="https://en.wikipedia.org/wiki/Operating_system">Wikipedia</a>, licensed <a href="https://creativecommons.org/licenses/by-sa/4.0/">CC BY-SA 4.0</a>.</p>
    <p class="text-gray-400 mb-6">How software manages hardware: processes, memory, files, and protection. Translated into runnable code and diagrams.</p>

    <!-- SVG: Layered diagram (hardware -> kernel -> user space) -->
    <div class="flex justify-center my-6">
      <svg viewBox="0 0 360 200" class="w-full max-w-sm" style="font-family: ui-monospace, monospace;">
        <!-- Hardware layer -->
        <rect x="40" y="140" width="280" height="45" rx="6" fill="none" stroke="#60a5fa" stroke-width="1.5" stroke-opacity="0.5"/>
        <text x="180" y="167" text-anchor="middle" fill="#60a5fa" font-size="13" fill-opacity="0.7">Hardware (CPU, RAM, Disk, I/O)</text>
        <!-- Kernel layer -->
        <rect x="60" y="80" width="240" height="45" rx="6" fill="none" stroke="#f59e0b" stroke-width="1.5" stroke-opacity="0.5"/>
        <text x="180" y="107" text-anchor="middle" fill="#f59e0b" font-size="13" fill-opacity="0.7">Kernel (OS)</text>
        <!-- User space layer -->
        <rect x="80" y="20" width="200" height="45" rx="6" fill="none" stroke="#34d399" stroke-width="1.5" stroke-opacity="0.5"/>
        <text x="180" y="47" text-anchor="middle" fill="#34d399" font-size="13" fill-opacity="0.7">User Space (Applications)</text>
        <!-- Arrows -->
        <line x1="180" y1="65" x2="180" y2="80" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>
        <polygon points="176,78 180,84 184,78" fill="currentColor" fill-opacity="0.3"/>
        <line x1="180" y1="125" x2="180" y2="140" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>
        <polygon points="176,138 180,144 184,138" fill="currentColor" fill-opacity="0.3"/>
      </svg>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-zinc-700">
            <th class="text-left py-2 pr-3 text-gray-400">Chapter</th>
            <th class="text-left py-2 pr-3 text-gray-400">One sentence</th>
            <th class="text-left py-2 text-gray-400"></th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300"><a href="/reading/operating-systems/os-01/">1. Processes</a></td>
            <td class="pr-3 text-gray-400">A program in execution with its own state, context, and lifecycle</td>
            <td><a href="/reading/operating-systems/os-01/" class="text-yellow-300 hover:text-yellow-200">🖥</a></td>
          </tr>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300"><a href="/reading/operating-systems/os-02/">2. Scheduling</a></td>
            <td class="pr-3 text-gray-400">Deciding which process runs next and for how long</td>
            <td><a href="/reading/operating-systems/os-02/" class="text-yellow-300 hover:text-yellow-200">🖥</a></td>
          </tr>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300"><a href="/reading/operating-systems/os-03/">3. Threads and Concurrency</a></td>
            <td class="pr-3 text-gray-400">Lightweight execution within a process sharing the same address space</td>
            <td><a href="/reading/operating-systems/os-03/" class="text-yellow-300 hover:text-yellow-200">🖥</a></td>
          </tr>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300"><a href="/reading/operating-systems/os-04/">4. Synchronization</a></td>
            <td class="pr-3 text-gray-400">Coordinating concurrent access to shared resources without corruption</td>
            <td><a href="/reading/operating-systems/os-04/" class="text-yellow-300 hover:text-yellow-200">🖥</a></td>
          </tr>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300"><a href="/reading/operating-systems/os-05/">5. Deadlock</a></td>
            <td class="pr-3 text-gray-400">When processes wait forever in a cycle of held resources</td>
            <td><a href="/reading/operating-systems/os-05/" class="text-yellow-300 hover:text-yellow-200">🖥</a></td>
          </tr>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300"><a href="/reading/operating-systems/os-06/">6. Memory Management</a></td>
            <td class="pr-3 text-gray-400">Translating virtual addresses to physical memory through paging and segmentation</td>
            <td><a href="/reading/operating-systems/os-06/" class="text-yellow-300 hover:text-yellow-200">🖥</a></td>
          </tr>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300"><a href="/reading/operating-systems/os-07/">7. Virtual Memory</a></td>
            <td class="pr-3 text-gray-400">The illusion of infinite memory backed by disk and page replacement</td>
            <td><a href="/reading/operating-systems/os-07/" class="text-yellow-300 hover:text-yellow-200">🖥</a></td>
          </tr>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300"><a href="/reading/operating-systems/os-08/">8. File Systems</a></td>
            <td class="pr-3 text-gray-400">Organizing persistent data into files, directories, and metadata</td>
            <td><a href="/reading/operating-systems/os-08/" class="text-yellow-300 hover:text-yellow-200">🖥</a></td>
          </tr>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300"><a href="/reading/operating-systems/os-09/">9. I/O Systems</a></td>
            <td class="pr-3 text-gray-400">Moving data between CPU and devices via polling, interrupts, and DMA</td>
            <td><a href="/reading/operating-systems/os-09/" class="text-yellow-300 hover:text-yellow-200">🖥</a></td>
          </tr>
          <tr>
            <td class="py-2 pr-3 text-gray-300"><a href="/reading/operating-systems/os-10/">10. Protection and Security</a></td>
            <td class="pr-3 text-gray-400">Controlling who can access what through access matrices and encryption</td>
            <td><a href="/reading/operating-systems/os-10/" class="text-yellow-300 hover:text-yellow-200">🖥</a></td>
          </tr>
        </tbody>
      </table>
    </div>


    <p class="text-gray-500 text-sm mt-8">📺 Video lectures: <a href="https://ocw.mit.edu/courses/6-828-operating-system-engineering-fall-2012/">MIT 6.828 Operating System Engineering</a></p>

    <Neighbors>
    <ul class="neighbors">
      <li><a href="/reading/algorithms/">⚙ Algorithms</a> &mdash; scheduling and memory management are algorithmic problems</li>
      <li><a href="/reading/distributed-systems/">🌐 Distributed Systems</a> &mdash; distributed OS and consensus protocols</li>
      <li><a href="/reading/programming/">🪄 Programming</a> &mdash; concurrency and streams connect to SICP</li>
      <li><a href="/reading/cryptography/">🔐 Cryptography</a> &mdash; trusted execution and protection mechanisms</li>
    </ul>
    </Neighbors>

  </main>
</Layout>
