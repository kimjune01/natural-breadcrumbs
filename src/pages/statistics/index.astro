---
import Layout from '../../layouts/Base.astro';
---

<Layout title="Statistics" favicon="📊">
  <main>

    <a href="/reading/" class="text-sm mb-4 inline-block">&larr; back to reading</a>

    <h1>📊 Statistics</h1>
    <p class="text-gray-400 mb-2">Based on <a href="https://openintro.org/book/os/">OpenIntro Statistics</a>, licensed <a href="https://creativecommons.org/licenses/by-sa/3.0/">CC BY-SA 3.0</a>.</p>
    <p class="text-gray-400 mb-6">Data analysis and inference, translated into runnable Python with diagrams.</p>

    <!-- SVG: Normal distribution bell curve with shaded 95% CI -->
    <div class="flex justify-center my-6">
      <svg viewBox="0 0 400 160" class="w-full max-w-md" style="font-family: ui-monospace, monospace;">
        <!-- Axes -->
        <line x1="30" y1="130" x2="370" y2="130" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>
        <!-- Bell curve path (standard normal, scaled) -->
        <path d="M 30,130 Q 60,128 80,125 Q 100,118 120,105 Q 140,82 160,55 Q 180,28 200,20 Q 220,28 240,55 Q 260,82 280,105 Q 300,118 320,125 Q 340,128 370,130" fill="none" stroke="currentColor" stroke-width="2" stroke-opacity="0.7"/>
        <!-- Shaded 95% CI region (approx -1.96 to +1.96 sigma) -->
        <path d="M 108,112 Q 120,105 140,82 Q 160,55 180,28 Q 200,20 220,28 Q 240,55 260,82 Q 280,105 292,112 L 292,130 L 108,130 Z" fill="#3b82f6" fill-opacity="0.2"/>
        <!-- Boundary lines at -1.96 and +1.96 sigma -->
        <line x1="108" y1="112" x2="108" y2="130" stroke="#3b82f6" stroke-width="1" stroke-dasharray="3,2" stroke-opacity="0.5"/>
        <line x1="292" y1="112" x2="292" y2="130" stroke="#3b82f6" stroke-width="1" stroke-dasharray="3,2" stroke-opacity="0.5"/>
        <!-- Labels -->
        <text x="200" y="80" text-anchor="middle" fill="#3b82f6" font-size="11" fill-opacity="0.7">95%</text>
        <text x="108" y="145" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.4">-1.96&#x3c3;</text>
        <text x="200" y="145" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.4">&#x3bc;</text>
        <text x="292" y="145" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.4">+1.96&#x3c3;</text>
        <!-- Caption -->
        <text x="200" y="158" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.3">Normal distribution with 95% confidence interval</text>
      </svg>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-zinc-700">
            <th class="text-left py-2 pr-3 text-gray-400">Chapter</th>
            <th class="text-left py-2 pr-3 text-gray-400">One sentence</th>
            <th class="text-left py-2 text-gray-400"></th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300">1. Introduction to Data</td>
            <td class="pr-3 text-gray-400">Observations, variables, study design, and sampling strategies</td>
            <td><a href="/reading/statistics/openintro-01/" class="text-yellow-300 hover:text-yellow-200">📊</a></td>
          </tr>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300">2. Summarizing Data</td>
            <td class="pr-3 text-gray-400">Histograms, box plots, measures of center and spread, contingency tables</td>
            <td><a href="/reading/statistics/openintro-02/" class="text-yellow-300 hover:text-yellow-200">📊</a></td>
          </tr>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300">3. Probability</td>
            <td class="pr-3 text-gray-400">Rules, conditional probability, Bayes' theorem, independence</td>
            <td><a href="/reading/statistics/openintro-03/" class="text-yellow-300 hover:text-yellow-200">📊</a></td>
          </tr>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300">4. Distributions</td>
            <td class="pr-3 text-gray-400">Normal, binomial, Poisson, and geometric distributions with Z-scores</td>
            <td><a href="/reading/statistics/openintro-04/" class="text-yellow-300 hover:text-yellow-200">📊</a></td>
          </tr>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300">5. Foundations for Inference</td>
            <td class="pr-3 text-gray-400">Point estimates, confidence intervals, hypothesis testing, p-values</td>
            <td><a href="/reading/statistics/openintro-05/" class="text-yellow-300 hover:text-yellow-200">📊</a></td>
          </tr>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300">6. Inference for Proportions</td>
            <td class="pr-3 text-gray-400">One- and two-sample proportion tests and confidence intervals</td>
            <td></td>
          </tr>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300">7. Inference for Means</td>
            <td class="pr-3 text-gray-400">t-tests, paired data, and the t-distribution</td>
            <td></td>
          </tr>
          <tr class="border-b border-zinc-800">
            <td class="py-2 pr-3 text-gray-300">8. Simple Regression</td>
            <td class="pr-3 text-gray-400">Least squares, residuals, correlation, and prediction</td>
            <td></td>
          </tr>
          <tr>
            <td class="py-2 pr-3 text-gray-300">9. Multiple Regression</td>
            <td class="pr-3 text-gray-400">Multiple predictors, adjusted R-squared, and model selection</td>
            <td></td>
          </tr>
        </tbody>
      </table>
    </div>

  </main>
</Layout>
