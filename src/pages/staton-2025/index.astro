    <!-- Rules table -->
    <h3>Rules reference (Theorem 79)</h3>
    <p class="mb-4">Every rule is a <strong>theorem</strong> in any posetal imperative category. Stoch is one (Corollary 76).</p>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-zinc-700">
